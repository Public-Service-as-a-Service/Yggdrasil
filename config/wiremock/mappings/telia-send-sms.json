{
  "priority": 1,
  "request": {
    "method": "POST",
    "url": "/sendSms",
    "headers": {
      "Content-Type": {
        "equalTo": "application/json"
      },
      "Authorization": {
        "matches": "Bearer .*"
      }
    },
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.originator"
      },
      {
        "matchesJsonPath": "$.destinationNumber"
      },
      {
        "matchesJsonPath": "$.message"
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    }
  }
}